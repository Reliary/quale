{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "agent-edit-tool-format",
  "type": "object",
  "required": ["schema_version", "risk", "confidence", "changed_files", "verification_mc", "scope_creep_guard"],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "risk": {"enum": ["low", "moderate", "high", "unknown"]},
    "confidence": {"enum": ["high", "mixed", "low", "unknown"]},
    "reason": {"type": "string"},
    "changed_files": {"type": "array", "items": {"type": "string"}},
    "read_first": {"type": ["array", "null"], "items": {"type": "string"}},
    "verification_mc": {
      "type": "object",
      "required": ["question", "candidates", "max_selections"],
      "properties": {
        "question": {"type": "string", "minLength": 5},
        "candidates": {"type": "array"},
        "max_selections": {"type": "integer", "minimum": 1},
        "types": {"type": "object"}
      }
    },
    "scope_creep_guard": {
      "type": "object",
      "required": ["allow_changed_files", "instruction", "never_block"],
      "properties": {
        "allow_changed_files": {"type": "array", "items": {"type": "string"}},
        "instruction": {"type": "string"},
        "never_block": {"type": "boolean"}
      }
    },
    "guardrails": {"type": "object"},
    "spectrum": {"type": ["object", "null"]},
    "deficit": {"type": ["object", "null"]},
    "cascade": {"type": ["object", "null"]}
  }
}
