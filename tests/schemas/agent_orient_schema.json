{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "agent-orient-output",
  "type": "object",
  "required": ["total_files", "languages", "landmarks", "modules", "recommended_workflow"],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "total_files": {"type": "integer", "minimum": 1},
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 2
      }
    },
    "landmarks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["file", "why"],
        "properties": {
          "file": {"type": "string"},
          "why": {"type": "string"}
        }
      }
    },
    "modules": {"type": "array"},
    "recommended_workflow": {
      "type": "array",
      "minItems": 2,
      "items": {"type": "string"}
    },
    "guard_list": {"type": "array"}
  }
}
